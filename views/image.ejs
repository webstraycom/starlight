<html>

<head>
    <link rel="stylesheet" href="http://localhost:3000/css/language-colors.css">
    <style>
        @font-face {
            font-family: "Inter"; 
            src: url("http://localhost:3000/fonts/Inter.ttf") format("truetype"); 
        }

        <% if (!light_theme) { %>
            :root {
                --default-color: #ffffff;
                --alternative-color: #8F8F8F;
                --default-background-color: #000000;
                --alternative-background-color: #1e1e1e;
            }    
        <% } else { %>
            :root {
                --default-color: #000000;
                --alternative-color: #8F8F8F;
                --default-background-color: #ffffff;
                --alternative-background-color: #e1e1e1;
            }
        <%} %>

        * {
            padding: 0;
            font-family: "Inter";
            font-optical-sizing: auto;
            font-style: normal;
        }

        *,
        *:before,
        *:after {
            box-sizing: border-box;
        }

        html,
        body {
            margin: 0;
            width: 1280px;
            height: 640px;
        }

        svg {
            stroke: var(--default-color);
        }

        .default-text {
            color: var(--default-color);
            font-size: 35px;
        }

        .image-background {
            padding: 75px;
            width: 100%;
            height: 100%;
            background-color: var(--default-background-color);;
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
            <% if (border_radius) { %>
                border-radius: <%=border_radius %>px;
            <% } else { %>
                <span class="default-text" style="font-size: 40px"><%=open_issues %></span>
            <%} %>
        }

        .first-line {
            opacity: 0.5;
            width: 100%;
            height: fit-content;
            display: flex;
        }

        .first-line .container {
            display: flex;
            justify-content: start;
            align-items: center;
        }

        .second-line {
            margin-top: 30px;
            display: inline-flex;
            justify-content: start;
            align-items: center;
        }

        .tags-container {
            display: inline-flex;
            padding-top: 4px;
        }

        .tags-container::after {
            position: absolute;
            right: 0;
            content: "";
            background: linear-gradient(270deg, var(--default-background-color) 40%, transparent);
            width: 200px;
            height: 45px;
        }

        .header {
            font-weight: bold;
            font-size: 58px;
            white-space: nowrap;
        }

        .tag {
            background-color: var(--alternative-background-color);
            font-size: 28px;
            padding: 5px 15px;
            color: var(--alternative-color);
            margin-left: 10px;
            border-radius: 25px;
            white-space: nowrap;
        }

        .third-line {
            margin-top: 30px;
            opacity: 0.5;
            width: 100%;
        }

        .fourth-line {
            margin-top: auto;
            width: 100%;
            display: inline-flex;
            opacity: 0.5;
        }

        .fourth-line .container {
            width: 100%;
            height: 50px;
            display: inline-flex;
            align-items: center;
        }

        .last-line {
            margin-top: auto;
        }

        .last-line .languages-bar {
            width: 100%;
            height: 20px;
            display: inline-flex;
            overflow: hidden;
            <% if (!sharp_progress) { %>
                border-radius: 30px;
            <%} %>
        }

        .languages-bar div {
            height: 100%;
        }

        .styled-progress {
            background-color: var(--default-color);
        }
    </style>
</head>

<body>
    <div class="image-background">
        <div class="first-line">
            <div class="container">
                <svg xmlns="http://www.w3.org/2000/svg" width="30" height="40" viewBox="0 0 24 20" fill="none"
                    stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                    class="lucide lucide-book-marked-icon lucide-book-marked">
                    <path d="M10 2v8l3-3 3 3V2" />
                    <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20" />
                </svg>
                <span style="margin-left: 10px;" class="default-text repository-info"><%=full_name %></span>
            </div>
            <div class="container" style="margin-left: auto;">
                <% if (homepage) { %>
                    <svg xmlns="http://www.w3.org/2000/svg" width="30" height="40" viewBox="0 0 24 20" fill="none"
                        stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                        class="lucide lucide-globe-icon lucide-globe">
                        <circle cx="12" cy="12" r="10" />
                        <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20" />
                        <path d="M2 12h20" />
                    </svg>
                    <span class="default-text repository-info" style="margin-left: 10px;"><%=homepage.replaceAll('https://', '').replaceAll('http://', '') %></span>
                <%} %>
            </div>
        </div>
        <div class="second-line">
            <% if (custom_title) { %>
                <span class="default-text header"><%=custom_title %></span>
            <% } else { %>
                <span class="default-text header"><%=name %></span>
            <% } %>
            <div class="tags-container">
                <% if (topics) { %>
                    <% for(let i = 0; i<topics.length; i++) {%>
                        <div class="tag default-text"><%=topics[i] %></div>
                    <%} %>
                <%} %>
            </div>
        </div>
        <div class="third-line">
            <% if (description) { %>
                <span class="default-text" style="font-size: 40px"><%=description %></span>
            <% } else { %>
                <span class="default-text" style="font-size: 40px">There is no description for this repository</span>
            <% } %>
        </div>
        <div class="fourth-line">
            <div class="container">
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none"
                    stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                    class="lucide lucide-star-icon lucide-star">
                    <path
                        d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z" />
                </svg>
                <span class="default-text" style="font-size: 40px; margin-left: 15px;">
                    <% if (stargazers_count >= 1000) { %>
                        <span class="default-text" style="font-size: 40px"><%=(stargazers_count / 1000).toFixed(1).replace(/\.0$/, '') + 'K' %></span>
                    <% } else { %>
                        <span class="default-text" style="font-size: 40px"><%=stargazers_count %></span>
                    <% } %>
                </span>
            </div>
            <div class="container">
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none"
                    stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                    class="lucide lucide-users-icon lucide-users">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                    <path d="M16 3.128a4 4 0 0 1 0 7.744" />
                    <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
                    <circle cx="9" cy="7" r="4" />
                </svg>
                <span class="default-text" style="font-size: 40px; margin-left: 15px;">
                    <% if (subscribers_count >= 1000) { %>
                        <span class="default-text" style="font-size: 40px"><%=(subscribers_count / 1000).toFixed(1).replace(/\.0$/, '') + 'K' %></span>
                    <% } else { %>
                        <span class="default-text" style="font-size: 40px"><%=subscribers_count %></span>
                    <% } %>
                </span>
            </div>
            <div class="container">
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none"
                    stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                    class="lucide lucide-circle-dot-icon lucide-circle-dot">
                    <circle cx="12" cy="12" r="10" />
                    <circle cx="12" cy="12" r="1" />
                </svg>
                <span class="default-text" style="font-size: 40px; margin-left: 15px;">
                    <% if (open_issues >= 1000) { %>
                        <span class="default-text" style="font-size: 40px"><%=(open_issues / 1000).toFixed(1).replace(/\.0$/, '') + 'K' %></span>
                    <% } else { %>
                        <span class="default-text" style="font-size: 40px"><%=open_issues %></span>
                    <% } %>
                </span>
            </div>
            <div class="container">
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none"
                    stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                    class="lucide lucide-git-fork-icon lucide-git-fork">
                    <circle cx="12" cy="18" r="3" />
                    <circle cx="6" cy="6" r="3" />
                    <circle cx="18" cy="6" r="3" />
                    <path d="M18 9v2c0 .6-.4 1-1 1H7c-.6 0-1-.4-1-1V9" />
                    <path d="M12 12v3" />
                </svg>
                <span class="default-text" style="font-size: 40px; margin-left: 15px;">
                    <% if (forks >= 1000) { %>
                        <span class="default-text" style="font-size: 40px"><%=(forks / 1000).toFixed(1).replace(/\.0$/, '') + 'K' %></span>
                    <% } else { %>
                        <span class="default-text" style="font-size: 40px"><%=forks %></span>
                    <% } %>
                </span>
            </div>
        </div>
        <div class="last-line">
            <div class="languages-bar">
                <% if (language && !styled_progress) { %>
                    <% if (!single_language) { %>
                        <% for (const [language, percentage] of Object.entries(languages)) { %>
                            <div class="<%=language.toLowerCase().replaceAll(' ', '-').replaceAll('#', 'sharp').replaceAll('+', 'p') %>" style="width: <%= percentage %>%"></div>
                        <% } %>
                    <% }else {%>
                            <div class="<%=language.toLowerCase().replaceAll(' ', '-').replaceAll('#', 'sharp').replaceAll('+', 'p') %>" style="width: 100%"></div>
                    <%} %>
                <% }else {%>
                    <div class="styled-progress" style="width: 100%"></div>
                <%} %>
            </div>
        </div>
    </div>
</body>

</html>